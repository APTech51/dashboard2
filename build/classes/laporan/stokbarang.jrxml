<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="stokbarang" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="b4d56f9b-3988-4704-a927-549aa6dfd134">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
        b.kd_brg AS id_bmg,
        b.nm_brg AS n_bmg,
        brg.ukuran AS ukuran, /* PERBAIKAN: Mengambil ukuran asli (M, L, XL) dari tabel barang */
        brg.Ktgrbrng AS ktgbrg, /* PERBAIKAN: Mengambil kategori asli dari tabel barang */
        brg.warna AS warna,    /* PERBAIKAN: Mengambil warna asli dari tabel barang */
        (COALESCE(m.total_masuk, 0) - COALESCE(k.total_keluar, 0)) AS jmlh
    FROM 
        (SELECT DISTINCT kd_brg, nm_brg FROM ts_brg_msk) b
        LEFT JOIN barang brg ON b.kd_brg = brg.kd_brng /* Relasi ke tabel master barang */
        LEFT JOIN (SELECT kd_brg, SUM(CAST(jumlah AS UNSIGNED)) AS total_masuk FROM ts_brg_msk GROUP BY kd_brg) m ON b.kd_brg = m.kd_brg
        LEFT JOIN (SELECT kd_brg, SUM(CAST(jm_keluar AS UNSIGNED)) AS total_keluar FROM ts_brg_klr GROUP BY kd_brg) k ON b.kd_brg = k.kd_brg]]>
	</queryString>
	<field name="id_bmg" class="java.lang.String"/>
	<field name="ktgbrg" class="java.lang.String"/>
	<field name="n_bmg" class="java.lang.String"/>
	<field name="ukuran" class="java.lang.String"/>
	<field name="warna" class="java.lang.String"/>
	<field name="jmlh" class="java.lang.String"/>
